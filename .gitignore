# Nim build artifacts
nimcache/
*.exe
*.dll
*.so
*.dylib

# Compiled binaries (examples)
# Match extensionless files: include all, then un-ignore sources
examples/*
!examples/*.nim
!examples/*.nims
!examples/README*

# Compiled binaries (tests)
tests/*
!tests/*.nim
!tests/*.nims

# Benchmark binaries
benchmarks/*
!benchmarks/*.nim
!benchmarks/*.nims
!benchmarks/README*

# Compiled VM engine binary
src/rteffects/vm/engine

# OS files
.DS_Store
Thumbs.db

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Test results (generated)
testresults/

# Specify template files (not needed in release)
.specify/
.codex/
